{
  "uid": "krishimitra-overview",
  "title": "KrishiMitra — System Overview",
  "description": "High-level health: all services, request rates, latency, error rates",
  "tags": ["krishimitra", "overview"],
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "Asia/Kolkata",
  "schemaVersion": 39,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Services Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"value": 0, "color": "red"}, {"value": 3, "color": "yellow"}, {"value": 5, "color": "green"}] },
          "mappings": [],
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "count(up{job=~\"krishimitra.*\"} == 1)",
        "legendFormat": "Services Up"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (rps)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 100, "color": "yellow"}, {"value": 500, "color": "red"}] } } },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"krishimitra-backend\"}[2m]))",
        "legendFormat": "req/s"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.5, "color": "yellow"}, {"value": 2, "color": "red"}] }
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"krishimitra-backend\"}[5m])) by (le))",
        "legendFormat": "p95"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.01, "color": "yellow"}, {"value": 0.05, "color": "red"}] }
        }
      },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"krishimitra-backend\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"krishimitra-backend\"}[5m]))",
        "legendFormat": "error %"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Active Farmers (24h)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } } },
      "targets": [{
        "expr": "increase(krishimitra_farmer_logins_total[24h])",
        "legendFormat": "logins"
      }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "ML Model (Custom %)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{"value": 0, "color": "red"}, {"value": 0.5, "color": "yellow"}, {"value": 0.8, "color": "green"}] }
        }
      },
      "targets": [{
        "expr": "sum(rate(krishimitra_requests_total{model=\"custom\",status=\"success\"}[10m])) / sum(rate(krishimitra_requests_total[10m]))",
        "legendFormat": "custom model %"
      }]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"krishimitra-backend\"}[2m]))", "legendFormat": "{{uri}}" }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Response Latency Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"krishimitra-backend\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"krishimitra-backend\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"krishimitra-backend\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "LLM Routing — Model Distribution",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "targets": [
        { "expr": "rate(krishimitra_requests_total{model=\"custom\",status=\"success\"}[5m])", "legendFormat": "Custom (primary)" },
        { "expr": "rate(krishimitra_requests_total{model=\"openai\",status=\"success\"}[5m])", "legendFormat": "OpenAI (fallback)" },
        { "expr": "rate(krishimitra_requests_total{model=\"claude\",status=\"success\"}[5m])", "legendFormat": "Claude (emergency)" }
      ]
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "ML Price Prediction — Cache vs Fresh",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "rate(krishimitra_ml_cache_hits_total[5m])", "legendFormat": "Cache hits" },
        { "expr": "rate(krishimitra_ml_cache_misses_total[5m])", "legendFormat": "Cache misses (ML called)" }
      ]
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "JVM Memory (Heap Used)",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=\"krishimitra-backend\",area=\"heap\"}", "legendFormat": "Heap used" },
        { "expr": "jvm_memory_max_bytes{job=\"krishimitra-backend\",area=\"heap\"}", "legendFormat": "Heap max" }
      ]
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "DB Connection Pool",
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "hikaricp_connections_active{job=\"krishimitra-backend\"}", "legendFormat": "Active" },
        { "expr": "hikaricp_connections_idle{job=\"krishimitra-backend\"}", "legendFormat": "Idle" },
        { "expr": "hikaricp_connections_pending{job=\"krishimitra-backend\"}", "legendFormat": "Pending (⚠️)" }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"value": 0,"color":"green"},{"value": 100,"color":"yellow"},{"value":1000,"color":"red"}] } } },
      "targets": [
        { "expr": "kafka_consumer_group_lag{group=\"krishimitra-backend\"}", "legendFormat": "{{topic}}" }
      ]
    }
  ]
}
