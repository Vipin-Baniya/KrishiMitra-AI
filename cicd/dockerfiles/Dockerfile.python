# ================================================================
#  KrishiMitra ML Engine — Production Dockerfile
#  Python 3.11 + CUDA 12.1 base for GPU training/inference
# ================================================================

# ── Stage 1: Builder (install heavy deps) ────────────────────
FROM python:3.11-slim AS builder
WORKDIR /build

# Build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ make libffi-dev libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --user --no-cache-dir -r requirements.txt

# ── Stage 2: Runtime ─────────────────────────────────────────
FROM python:3.11-slim AS production
WORKDIR /app

# Security: non-root
RUN addgroup --gid 1001 krishimitra && \
    adduser  --uid 1001 --gid 1001 --no-create-home --disabled-password krishimitra

# Runtime system deps only
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /root/.local /home/krishimitra/.local
ENV PATH=/home/krishimitra/.local/bin:$PATH

COPY --chown=krishimitra:krishimitra . .
RUN mkdir -p models/registry logs data/processed && \
    chown -R krishimitra:krishimitra models logs data

USER krishimitra

EXPOSE 8003

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8003/health || exit 1

CMD ["uvicorn", "serving.server:app", \
     "--host", "0.0.0.0", "--port", "8003", \
     "--workers", "2", "--loop", "uvloop", "--access-log"]

---
# ================================================================
#  KrishiMitra LLM Serving — Production Dockerfile
# ================================================================

FROM python:3.11-slim AS production
WORKDIR /app

RUN addgroup --gid 1001 krishimitra && \
    adduser  --uid 1001 --gid 1001 --no-create-home --disabled-password krishimitra

RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn httpx openai anthropic pyyaml \
    prometheus-client pydantic

COPY --chown=krishimitra:krishimitra . .
USER krishimitra

EXPOSE 8001

HEALTHCHECK --interval=20s --timeout=8s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

CMD ["uvicorn", "serving.inference_server:app", \
     "--host", "0.0.0.0", "--port", "8001", \
     "--workers", "2", "--loop", "uvloop"]

---
# ================================================================
#  KrishiMitra Frontend — Production Dockerfile
# ================================================================

FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm ci --silent

COPY . .
ARG VITE_API_URL=""
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

# Production: serve with nginx
FROM nginx:1.27-alpine AS production
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx-spa.conf /etc/nginx/conf.d/default.conf

# SPA routing config
RUN cat > /etc/nginx/conf.d/default.conf << 'EOF'
server {
    listen 80;
    root /usr/share/nginx/html;
    gzip on;
    gzip_types text/plain text/css application/json application/javascript;
    location / {
        try_files $uri $uri/ /index.html;
    }
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
EOF

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost:80 || exit 1
