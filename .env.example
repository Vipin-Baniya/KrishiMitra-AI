# ================================================================
#  KrishiMitra AI — Environment Variables
#  Copy this file to .env and fill in all REQUIRED values.
#
#  Usage:
#    cp .env.example .env
#    # Edit .env with real values
#    docker compose -f integration/docker-compose.full.yml up -d
# ================================================================

# ── REQUIRED: Security ────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# ── REQUIRED: Database ────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=postgres         # "postgres" in Docker, RDS endpoint in prod
POSTGRES_PORT=5432

# ── REQUIRED: Redis ───────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_HOST=redis               # "redis" in Docker, ElastiCache endpoint in prod
REDIS_PORT=6379

# ── REQUIRED: Kafka ───────────────────────────────────────────
KAFKA_BROKERS=kafka:9092       # "kafka:9092" in Docker, MSK endpoint in prod

# ── OPTIONAL: LLM APIs (fallback chain) ──────────────────────
# The platform works without these — custom model runs locally.
# OpenAI is the first fallback if custom model confidence < 0.72.
OPENAI_API_KEY=sk-...          # Get from: https://platform.openai.com/api-keys

# Claude is the emergency fallback if OpenAI is also down.
ANTHROPIC_API_KEY=sk-ant-...   # Get from: https://console.anthropic.com

# ── OPTIONAL: Data ingestion ──────────────────────────────────
# Required to pull live prices from Agmarknet (data.gov.in).
# Without this, the ML engine uses cached data only.
# Register at: https://data.gov.in/user/register
DATAGOV_API_KEY=your_datagov_key_here

# ── OPTIONAL: Notifications ──────────────────────────────────
# SMS and WhatsApp via Twilio (for farmers without smartphones).
# Without this, only push notifications work.
# Register at: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SMS_FROM=+91XXXXXXXXXX          # Your Twilio number (India)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox or approved sender

# Firebase Cloud Messaging (Android push notifications)
# Download service account JSON from Firebase Console → Project Settings → Service accounts
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_PATH=/app/config/firebase-service-account.json

# ── OPTIONAL: Monitoring ──────────────────────────────────────
GRAFANA_PASSWORD=krishimitra           # Grafana admin password
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
PAGERDUTY_SERVICE_KEY=your_pagerduty_key

# ── OPTIONAL: ML training ─────────────────────────────────────
# Required only when running model training (not for serving).
WANDB_API_KEY=your_wandb_key           # Weights & Biases experiment tracking

# ── OPTIONAL: Deployment ─────────────────────────────────────
# Only needed for Helm/k8s production deploys.
DOMAIN=krishimitra.in                  # Your domain name
IMAGE_TAG=latest                       # Docker image tag to deploy
PG_EXPORTER_DSN=postgresql://krishimitra:${POSTGRES_PASSWORD}@postgres:5432/krishimitra?sslmode=disable

# ── FRONTEND (build-time) ────────────────────────────────────
# Leave empty in Docker — nginx proxies /api/* to backend.
# Set to https://krishimitra.in when building for standalone deploy.
VITE_API_URL=

# ── MOBILE (React Native) ────────────────────────────────────
# Set to your machine's LAN IP when testing on a physical device.
# Android emulator uses 10.0.2.2 to reach host localhost (automatic).
# REACT_NATIVE_API_URL=http://192.168.1.x:8080

# ── SMTP (optional email alerts) ─────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=alerts@krishimitra.in
SMTP_PASSWORD=your_smtp_app_password
